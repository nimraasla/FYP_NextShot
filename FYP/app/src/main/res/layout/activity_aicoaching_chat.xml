<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".AICoachingChat">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F0F4FF"
        android:orientation="vertical">

        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:elevation="4dp"
            android:background="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="12dp"
                android:paddingHorizontal="16dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <androidx.appcompat.widget.Toolbar
                    android:id="@+id/toolbar"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    app:navigationIcon="@drawable/hamburger"
                    app:navigationIconTint="#002B5C"
                    android:contentDescription="Menu" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp"
                    android:layout_marginStart="8dp"
                    app:cardBackgroundColor="#E3F2FD">
                     <ImageView
                         android:layout_width="24dp"
                         android:layout_height="24dp"
                         android:layout_gravity="center"
                         android:src="@drawable/img_14" 
                         app:tint="#002B5C"/>
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AI Cricket Coach"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#002B5C" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="2dp">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            app:cardCornerRadius="4dp"
                            app:cardBackgroundColor="#00E676"
                            app:strokeWidth="0dp"
                            android:layout_marginEnd="6dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Online • Always ready"
                            android:textSize="12sp"
                            android:textColor="#546E7A" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.appbar.AppBarLayout>

        <ScrollView
            android:id="@+id/scrollView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="16dp"
            android:background="#F0F4FF">

            <LinearLayout
                android:id="@+id/chatContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
            </LinearLayout>
        </ScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="bottom"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp"
            android:background="#F0F4FF">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:minHeight="48dp">

                    <ImageView
                        android:id="@+id/btnMic"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@drawable/mic"
                        android:padding="11dp"
                        android:layout_marginStart="4dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true"
                        app:tint="#546E7A" />

                    <EditText
                        android:id="@+id/inputMessage"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Ask me anything..."
                        android:background="@null"
                        android:paddingHorizontal="4dp"
                        android:paddingVertical="12dp"
                        android:textColorHint="#90A4AE"
                        android:textColor="#002B5C"
                        android:textSize="15sp"
                        android:maxLines="4"
                        android:inputType="textCapSentences|textMultiLine" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/btnSend"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="1dp"
                android:src="@drawable/ic_send"
                app:tint="#FFFFFF"
                app:backgroundTint="#002B5C"
                app:fabCustomSize="46dp"
                app:maxImageSize="22dp"
                app:elevation="2dp"
                android:contentDescription="Send" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/bottomNavBar"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:orientation="horizontal"
            android:background="#002B5C"
            android:gravity="center"
            android:elevation="8dp">

            <LinearLayout
                android:id="@+id/btnDashboard"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">

                <ImageView
                    android:src="@drawable/img_11"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:contentDescription="Dashboard"
                    app:tint="#90A4AE"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:text="Dashboard"
                    android:textColor="#90A4AE"
                    android:textSize="10sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnPractice"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">

                <ImageView
                    android:src="@drawable/img_12"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:contentDescription="Practice"
                    app:tint="#90A4AE"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:text="Practice"
                    android:textColor="#90A4AE"
                    android:textSize="10sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnProgress"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">

                <ImageView
                    android:src="@drawable/img_13"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:contentDescription="Progress"
                    app:tint="#90A4AE"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:text="Progress"
                    android:textColor="#90A4AE"
                    android:textSize="10sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnTips"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">

                <ImageView
                    android:src="@drawable/img_14"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:contentDescription="Tips"
                    app:tint="#90A4AE"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:text="Tips"
                    android:textColor="#90A4AE"
                    android:textSize="10sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@android:color/white"
        app:headerLayout="@layout/header"
        app:menu="@menu/main_menu"
        app:itemIconTint="@color/drawer_item_selector"
        app:itemTextColor="@color/drawer_item_selector" />

</androidx.drawerlayout.widget.DrawerLayout>