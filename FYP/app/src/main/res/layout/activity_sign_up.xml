<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/words_blue">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Header Section (Blue Background) -->
            <LinearLayout
                android:id="@+id/headerSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/words_blue"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="16dp"
                android:paddingBottom="15dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <!-- Logo and App Name Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="start|center_vertical">

                    <ImageView
                        android:id="@+id/appLogo"
                        android:layout_marginTop="-20dp"
                        android:layout_width="120dp"
                        android:layout_height="150dp"
                        android:src="@drawable/img_1"
                        android:scaleType="centerInside" />

                    <TextView
                        android:id="@+id/appName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="-15dp"
                        android:layout_marginTop="-20dp"
                        android:text="NextShot"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium" />

                </LinearLayout>

                <!-- Subtitle -->
                <TextView
                    android:id="@+id/subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_marginTop="-40dp"
                    android:text="AI Cricket Batting Coach"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:alpha="0.9" />

                <!-- Welcome Text -->
                <TextView
                    android:id="@+id/welcomeText1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:text="Hey!"
                    android:textColor="@color/white"
                    android:textSize="40sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-black" />

                <TextView
                    android:id="@+id/welcomeText2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Join NextShot"
                    android:textColor="@color/white"
                    android:textSize="40sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-black" />

            </LinearLayout>

            <!-- Form Section (White Background with Rounded Top) -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/formSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/rounded_top_corners_shape"
                android:paddingTop="32dp"
                android:paddingBottom="32dp"
                app:layout_constraintTop_toBottomOf="@id/headerSection"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <!-- Sign In / Sign Up Toggle -->
                <LinearLayout
                    android:id="@+id/toggleBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2"
                    android:paddingStart="40dp"
                    android:paddingEnd="40dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <!-- Sign In Tab (Inactive) -->
                    <TextView
                        android:id="@+id/signInTab"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Sign In"
                        android:textSize="20sp"
                        android:textColor="@color/light_blue"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium" />

                    <!-- Sign Up Tab (Active) -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/signUpTab"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sign Up"
                            android:textSize="20sp"
                            android:textColor="@color/words_blue"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium" />

                        <View
                            android:layout_width="80dp"
                            android:layout_height="4dp"
                            android:layout_marginTop="8dp"
                            android:background="@color/words_blue" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Form Fields Container -->
                <LinearLayout
                    android:id="@+id/formFieldsContainer"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="32dp"
                    app:layout_constraintTop_toBottomOf="@id/toggleBar"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintWidth_percent="0.85">

                    <!-- Full Name Field -->
                    <TextView
                        android:id="@+id/nameLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Full Name"
                        android:textColor="@color/words_blue"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/nameInput"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/button_edittext"
                        android:backgroundTint="@color/white"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:inputType="textPersonName"
                        android:textSize="15sp"
                        android:hint="Enter your full name"
                        android:textColor="@color/words_blue"
                        android:textColorHint="#80000000" />

                    <!-- Email Field -->
                    <TextView
                        android:id="@+id/emailLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:text="Email"
                        android:textColor="@color/words_blue"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/emailInput"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/button_edittext"
                        android:backgroundTint="@color/white"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:inputType="textEmailAddress"
                        android:textSize="15sp"
                        android:hint="Enter your email"
                        android:textColor="@color/words_blue"
                        android:textColorHint="#80000000" />

                    <!-- Password Field -->
                    <TextView
                        android:id="@+id/passwordLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:text="Password"
                        android:textColor="@color/words_blue"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="8dp">

                        <EditText
                            android:id="@+id/passwordInput"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/button_edittext"
                            android:backgroundTint="@color/white"
                            android:paddingStart="16dp"
                            android:paddingEnd="48dp"
                            android:inputType="textPassword"
                            android:textColor="@color/words_blue"
                            android:textSize="15sp"
                            android:hint="Create a password"
                            android:textColorHint="#80000000" />

                        <ImageView
                            android:id="@+id/passwordToggle"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:layout_marginEnd="12dp"
                            android:src="@drawable/img_3"
                            android:scaleType="centerInside" />

                    </RelativeLayout>

                    <!-- Create Account Button -->
                    <Button
                        android:id="@+id/createAccountButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="32dp"
                        android:backgroundTint="@color/words_blue"
                        android:text="Create an Account"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:elevation="2dp"
                        app:cornerRadius="28dp" />

                    <!-- Already have account text -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Already have an account? "
                            android:textColor="@color/words_blue"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/signInLink"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sign In"
                            android:textColor="@color/words_blue"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>