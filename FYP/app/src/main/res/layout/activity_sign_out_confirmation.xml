<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#E8F2FF"
    android:gravity="center">

    <!-- Main Content Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_card_rounded"
        android:padding="30dp"
        android:layout_margin="20dp"
        android:gravity="center">

        <!-- Logo -->
        <ImageView
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/img_1"
            android:contentDescription="App Logo"
            android:layout_marginBottom="20dp" />

        <!-- App Name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NextShot"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#002B5C"
            android:layout_marginBottom="30dp" />

        <!-- Icon -->
        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/logout"
            android:contentDescription="Logout Icon"
            android:layout_marginBottom="25dp" />

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Oh no! You're Leaving..."
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#002B5C"
            android:gravity="center"
            android:layout_marginBottom="15dp" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Are you sure?"
            android:textSize="16sp"
            android:textColor="#90A4AE"
            android:gravity="center"
            android:layout_marginBottom="30dp" />

        <!-- Cancel Button -->
        <Button
            android:id="@+id/btnCancel"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="32dp"
            android:backgroundTint="@color/words_blue"
            android:text="Nah, Just Kidding"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:elevation="2dp"
            app:cornerRadius="28dp" />


        <Button
            android:id="@+id/btnConfirmLogout"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="2dp"
            android:backgroundTint="@color/words_blue"
            android:text="Yes, Log Me Out"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:elevation="2dp"
            app:cornerRadius="28dp" />

    </LinearLayout>

</LinearLayout>