<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#E8F2FF"
    android:padding="20dp">

    <!-- Back Button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="20dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_back"
            android:contentDescription="Back"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- Icon -->
    <ImageView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/lock"
        android:layout_gravity="center"
        android:contentDescription="Lock Icon"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="30dp" />

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="New Password"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#002B5C"
        android:gravity="center"
        android:layout_marginBottom="30dp" />

    <!-- New Password Input -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Enter New Password"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#002B5C"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/bg_input_field"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:layout_marginBottom="20dp">

        <EditText
            android:id="@+id/etNewPassword"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:hint="••••••••••"
            android:inputType="textPassword"
            android:textColorHint="#90A4AE"
            android:textColor="#002B5C"
            android:textSize="14sp"
            android:background="@android:color/transparent"
            android:gravity="center_vertical" />

        <ImageView
            android:id="@+id/btnToggleNewPassword"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/img_3"
            android:contentDescription="Toggle Password"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <!-- Confirm Password Input -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Confirm Password"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#002B5C"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/bg_input_field"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:layout_marginBottom="30dp">

        <EditText
            android:id="@+id/etConfirmPassword"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:hint="••••••••••"
            android:inputType="textPassword"
            android:textColorHint="#90A4AE"
            android:textColor="#002B5C"
            android:textSize="14sp"
            android:background="@android:color/transparent"
            android:gravity="center_vertical" />

        <ImageView
            android:id="@+id/btnToggleConfirmPassword"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/img_3"
            android:contentDescription="Toggle Password"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <!-- Send Button -->
    <Button
        android:id="@+id/btnSend"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="2dp"
        android:backgroundTint="@color/words_blue"
        android:text="Send"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:elevation="2dp"
        app:cornerRadius="28dp" />

</LinearLayout>